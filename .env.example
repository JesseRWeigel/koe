# Database (required)
DATABASE_URL="postgresql://user:password@host:5432/koe"

# AI Provider - Local (Ollama) — free, runs on your GPU
OLLAMA_BASE_URL="http://localhost:11434"
DEFAULT_AI_PROVIDER="ollama"  # "ollama" for local, "gateway" for cloud

# AI Provider - Cloud (Vercel AI Gateway)
# Run `vercel link && vercel env pull` to auto-provision these
# VERCEL_OIDC_TOKEN is managed automatically on Vercel deployments

# Text-to-Speech (optional)
# Leave blank to use browser-native TTS as fallback
ELEVENLABS_API_KEY=""
